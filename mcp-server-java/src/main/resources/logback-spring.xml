<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!--
         CRITICAL for stdio MCP: ALL log output must go to stderr.
         Anything on stdout will corrupt the JSON-RPC stream that Claude Desktop reads.
    -->
    <appender name="STDERR" class="ch.qos.logback.core.ConsoleAppender">
        <target>System.err</target>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [%thread] %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <root level="WARN">
        <appender-ref ref="STDERR"/>
    </root>

    <logger name="com.jimmy.mcp" level="INFO"/>
</configuration>
